# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL 连接字符串
# 格式：postgres://用户名:密码@主机:端口/数据库名?sslmode=disable
# 生产环境：主机使用 docker-compose 服务名 "db"
DATABASE_URL=postgres://bta:CHANGE_ME_STRONG_PASSWORD@db:5432/bta_voting?sslmode=disable

# =============================================================================
# JWT 认证（必须修改！）
# 生产环境请使用强随机字符串，建议 64 字符以上
# 生成方法：openssl rand -hex 32
# =============================================================================

JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_hex_32_DIFFERENT_FROM_ABOVE

# =============================================================================
# 邮件发送配置
# EMAIL_PROVIDER 选择邮件发送方式：
#   smtp   - 使用标准 SMTP 协议（填写下方 SMTP_* 字段）
#   resend - 使用 Resend API（填写下方 RESEND_API_KEY 字段）
# =============================================================================

EMAIL_PROVIDER=smtp

# 所有外发邮件的发件人地址（From 字段）
EMAIL_FROM=noreply@yourdomain.com

# --- SMTP 配置（EMAIL_PROVIDER=smtp 时填写）---
SMTP_HOST=smtp.example.com
# 常见端口：587（STARTTLS）、465（SSL/TLS）
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password

# --- Resend 配置（EMAIL_PROVIDER=resend 时填写）---
# 在 https://resend.com 获取 API Key
RESEND_API_KEY=

# =============================================================================
# 文件存储
# =============================================================================

BLOB_PROVIDER=file
BLOB_FILE_PATH=./uploads

# =============================================================================
# 服务器配置（重要！）
# =============================================================================

# 后端监听端口（容器内部端口，通常不需要修改）
SERVER_PORT=8080

# 前端地址（Vercel 部署后的域名）
# 用于 CORS 白名单和邮件中的链接生成
# 示例：https://bta-voting.vercel.app
FRONTEND_URL=https://your-vercel-domain.vercel.app

# 后端基础 URL（你的后端公网访问地址）
# 用于生成封面图等静态资源的完整 URL
# 示例：https://api.yourdomain.com
BACKEND_BASE_URL=https://your-backend-domain.com

# 静态文件上传目录（容器内路径，通常不需要修改）
UPLOAD_DIR=./uploads

# =============================================================================
# Cookie 配置（生产环境必须启用 Secure）
# =============================================================================

# Cookie Secure 属性：生产环境必须设为 true（仅通过 HTTPS 传输）
COOKIE_SECURE=true

# Cookie SameSite 属性：防止 CSRF 攻击
# 可选值：Lax（推荐）、Strict、None
# 注意：如果前后端跨域且需要携带 Cookie，使用 None 并确保 Secure=true
COOKIE_SAMESITE=Lax

# Cookie Domain 属性：跨子域共享 cookie 时设置（如 .yourdomain.com）
# 留空表示使用默认（当前域名）
# 注意：如果前端在 Vercel，后端在自己的域名，通常留空
COOKIE_DOMAIN=
